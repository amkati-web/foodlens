# Nebius AI Studio (OpenAI-compatible) credentials
NEBIUS_API_KEY=your_nebius_api_key_here
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_LLM_MODEL=Qwen/Qwen3-1.7B
# Set to the fine-tuned model name/path once trained & deployed as a Nebius Endpoint
NEBIUS_FINE_TUNED_MODEL=

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Nebius Jobs / Object Storage (used only by training/ scripts)
NEBIUS_PROJECT_ID=
NEBIUS_BUCKET=foodlens-datasets
